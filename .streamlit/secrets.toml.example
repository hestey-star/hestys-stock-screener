# Kopieer dit bestand naar .streamlit/secrets.toml en vul je eigen waarden in.
#
# BELANGRIJK: voeg .streamlit/secrets.toml toe aan je .gitignore -- dit
# bestand mag NOOIT naar GitHub gepusht worden (bevat wachtwoorden/sleutels).
#
# Voor Streamlit Community Cloud: plak deze inhoud (met je eigen waarden)
# in de "Secrets"-sectie van je app-instellingen, in plaats van een los
# bestand te uploaden.

[auth]
# Voor lokaal testen. Zodra je live gaat, pas je dit aan naar je echte
# domein, bv. "https://jouw-app-naam.streamlit.app/oauth2callback"
redirect_uri = "http://localhost:8501/oauth2callback"
# Verzin hier een lange, willekeurige tekenreeks (bv. via een wachtwoord-generator)
cookie_secret = "verzin-hier-een-lange-willekeurige-tekenreeks"
# Deze twee kopieer je uit Google Cloud Console (stap 1 in de instructies)
client_id = "jouw-google-client-id.apps.googleusercontent.com"
client_secret = "jouw-google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[supabase]
# Deze twee kopieer je uit Supabase, Project Settings -> API
url = "https://jouw-project-id.supabase.co"
anon_key = "jouw-anon-public-key"

[email]
# Zelfde e-mail-instellingen als eerder in je .env
smtp_server = "smtp.gmail.com"
smtp_port = 587
address = "jouw@gmail.com"
app_password = "jouw-app-wachtwoord"

[stripe]
# Uit Stripe -> Ontwikkelaars/Developers -> API-sleutels (test-sleutels om mee te beginnen)
publishable_key = "pk_test_..."
secret_key = "sk_test_..."
# Uit je Stripe-product: de 2 Price ID's (maandelijks + jaarlijks)
price_id_monthly = "price_..."
price_id_yearly = "price_..."

[app]
# Je live Streamlit-URL, nodig zodat Stripe je na betaling kan terugsturen
url = "https://hestys-stock-screener.streamlit.app"
